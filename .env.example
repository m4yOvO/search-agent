APP_ENV=production
LOG_LEVEL=INFO

# Production runtime is OpenAI-only. Keep the example key empty and set it in
# the untracked .env file before starting Docker Compose.
AGENT_MODE=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2
CHAT_TIMEOUT_SECONDS=570
AGENT_MAX_ITERATIONS=20

CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
# v18 isolates the current task-DAG prompts and mixed-relation Visualizer from older cache rows.
CHROMA_COLLECTION_PREFIX=enterprise_query_cache_v18
CHROMA_CONNECT_RETRIES=12
CHROMA_RETRY_DELAY_SECONDS=1.0

SHORT_TERM_MAX_TURNS=15
SHORT_TERM_COMPACT_OLDEST=10
SHORT_TERM_KEEP_RECENT=5

CACHE_TTL_HOURS=24
GRAPH_SCHEMA_VERSION=1
QUERY_SIGNATURE_VERSION=4
PERMISSION_SCOPE=public-demo

MAX_RESEARCH_STEPS=12
MAX_TOOL_CALLS=10
MAX_REPLANS=2
RESEARCH_RETRY_STEP_ALLOWANCE=3
GRAPH_RECURSION_LIMIT=64
TOOL_TIMEOUT_SECONDS=5

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000
CHROMA_HOST_PORT=8001
